{
  "name": "ecclesiapp-backend",
  "version": "1.0.0",
  "description": "Professional Church Application Backend - Node.js + Express + PostgreSQL",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "test": "jest",
    "test:watch": "jest --watch",
    "lint": "eslint src --ext .ts",
    "format": "prettier --write \"src/**/*.ts\"",
    "migrate": "prisma migrate dev",
    "migrate:prod": "prisma migrate deploy",
    "seed": "ts-node prisma/seed.ts"
  },
  "keywords": [
    "church",
    "holyrics",
    "songs",
    "projection",
    "worship"
  ],
  "author": "EcclesiApp Team",
  "license": "GPL-3.0",
  "dependencies": {
    "@prisma/client": "^5.0.0",
    "express": "^4.18.2",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "jsonwebtoken": "^9.1.0",
    "bcryptjs": "^2.4.3",
    "axios": "^1.5.0",
    "multer": "^1.4.5-lts.1",
    "socket.io": "^4.7.0",
    "helmet": "^7.0.0",
    "express-validator": "^7.0.0",
    "class-validator": "^0.14.0",
    "typeorm": "^0.3.16",
    "compression": "^1.7.4",
    "uuid": "^9.0.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.17",
    "@types/node": "^20.4.2",
    "@types/jest": "^29.5.3",
    "@types/cors": "^2.8.14",
    "@types/bcryptjs": "^2.4.2",
    "typescript": "^5.1.6",
    "tsx": "^3.14.0",
    "ts-node": "^10.9.1",
    "eslint": "^8.46.0",
    "@typescript-eslint/eslint-plugin": "^6.3.0",
    "@typescript-eslint/parser": "^6.3.0",
    "prettier": "^3.0.1",
    "jest": "^29.6.2",
    "ts-jest": "^29.1.1",
    "prisma": "^5.0.0"
  }
}
